# OpenAI — 추출(gpt-4.1-mini) + 이미지(gpt-image-2)
OPENAI_API_KEY=sk-...

# Neon Postgres (작업 상태 저장). Neon 대시보드 > Connection string
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# Vercel Blob (생성 이미지 저장). `vercel blob` 또는 대시보드에서 발급
# 로컬에서는 `vercel env pull`로 받거나 여기에 직접 설정
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Sentry (에러 추적). sentry.io 프로젝트의 DSN. 비우면 Sentry 비활성(에러 안 보냄).
NEXT_PUBLIC_SENTRY_DSN=
# (선택) 소스맵 업로드 → 프로덕션 스택트레이스 가독성. 셋 다 있어야 빌드 시 업로드.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
